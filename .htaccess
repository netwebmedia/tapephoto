# tapephoto.com — Apache 2.4

Options -Indexes

RewriteEngine On

# Force HTTPS + canonical non-www host
# (non-www is required: the NetWebMedia forms API CORS allowlist
#  only accepts https://tapephoto.com)
# ACME HTTP-01 challenges (cPanel AutoSSL) are exempt — never redirect them.
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^(.*)$ https://tapephoto.com/$1 [L,R=301]

# Cache policy: images 1 year immutable, HTML never cached,
# CSS/JS short cache with revalidation
<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>
